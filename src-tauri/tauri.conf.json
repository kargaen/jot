{
  "productName": "Jot",
  "version": "1.0.0",
  "identifier": "com.jot.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Jot — Dashboard",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false,
        "decorations": true,
        "center": true
      },
      {
        "label": "quick-capture",
        "title": "Quick Capture",
        "width": 480,
        "height": 280,
        "decorations": false,
        "visible": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "center": true
      },
      {
        "label": "about",
        "title": "About Jot",
        "width": 380,
        "height": 340,
        "decorations": false,
        "visible": false,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      },
      "wix": {}
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxQTdDQ0M5NUY5MTlDNTkKUldSWm5KRmZ5Y3luOFRRbDA0WG1pTDBOQ1Z4N2JkM25BS0JRalM4ZVlydnpJeVJKeEl2NCtOUVQK",
      "endpoints": [
        "https://github.com/kargaen/jot/releases/latest/download/latest.json"
      ]
    }
  }
}
